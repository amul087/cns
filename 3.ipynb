   "source": [
    "from math import gcd\n",
    "\n",
    "def rsa(p, q, m):\n",
    "    n=p*q; t=(p-1)*(q-1)\n",
    "    e=next(e for e in range(2,t) if gcd(e,t)==1)\n",
    "    ct=pow(m,e,n)\n",
    "    print('Encrypted:', ct, '| Decrypted:', pow(ct,pow(e,-1,t),n))\n",
    "\n",
    "rsa(3,7,9)\n",
    "rsa(3,7,17)"
   ]
  },
